{
  "topic": "domain_extremums",
  "display_name": "Область определения и точки экстремума",
  "curriculum_ref": "10 класс — Свойства функции",
  "constraints_template": "domain_extremums.j2",

  "_comment": "Нахождение ОДЗ (знаменатель != 0, корень >= 0) и теоретическое определение экстремумов по графику.",

  "tag": { "name": "Область определения и экстремумы", "slug": "odf-i-ekstremumy" },
  "default_difficulty": 2,

  "parameters": {
    "denom_a": { "type": "int", "min": 1, "max": 5, "desc": "Коэффициент при x в знаменателе" },
    "denom_b": { "type": "int", "min": 1, "max": 10, "desc": "Свободный член в знаменателе" },
    "root_c": { "type": "int", "min": 1, "max": 4, "desc": "Коэффициент при x под корнем" },
    "root_d": { "type": "int", "min": -12, "max": -2, "desc": "Свободный член под корнем" }
  },

  "difficulty_overrides": {
    "1": { "denom_b": { "max": 4 }, "root_d": { "min": -4 } },
    "2": { "denom_b": { "max": 7 }, "root_d": { "min": -8 } },
    "3": { "denom_b": { "max": 10 }, "root_d": { "min": -12 } }
  },

  "constraints": [
    "denom_b % denom_a == 0 // Исключенная точка знаменателя - целое число",
    "root_d % root_c == 0 // Граница подкоренного выражения - целое число"
  ],

  "integer_clean": true,

  "answer": {
    "type": "static_choice",
    "correct": {
      "ооф_дроби": "(-inf, {{ -(denom_b//denom_a) }}) U ({{ -(denom_b//denom_a) }}, +inf)",
      "ооф_корня": "[{{ -(root_d//root_c) }}, +inf)",
      "экстремум": "Значения x, в которых убывание сменяется возрастанием или наоборот"
    },
    "desc": "ОДЗ: знаменатель != 0 (выколотая точка -denom_b/denom_a) и подкоренное >= 0 (граница -root_d/root_c). answer_key = correct."
  },

  "distractors": [
    { "id": "root_strict_inequality", "desc": "Использовал строгое неравенство для подкоренного выражения (> 0 вместо >= 0).", "transform": { "ооф_корня": "({{ -(root_d//root_c) }}, +inf)" } },
    { "id": "fraction_forgot_minus", "desc": "Ошибся знаком при переносе свободного члена знаменателя.", "transform": { "ооф_дроби": "(-inf, {{ denom_b//denom_a }}) U ({{ denom_b//denom_a }}, +inf)" } },
    { "id": "extremum_is_y", "desc": "Перепутал экстремумы (значения x) с наибольшим/наименьшим значением функции (значения y).", "transform": { "экстремум": "Максимальное или минимальное значение y" } }
  ],

  "narrative_settings": [
    "поиск ограничений для физических процессов",
    "определение точек перелома тренда"
  ]
}