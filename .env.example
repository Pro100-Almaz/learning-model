# --------------------------------------------------------------------------------
# ⚡ Basic Config: for development and testing.
# --------------------------------------------------------------------------------
DEBUG=True
DJANGO_SECRET_KEY=django-insecure-wlgjuo53y49%-4y5(!%ksylle_ud%b=7%__@9hh+@$$d%_^y3s!

# --------------------------------------------------------------------------------
# 🗄️ Database
# --------------------------------------------------------------------------------
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# --------------------------------------------------------------------------------
# 📧 Email Config: optional and can be copied if needed.
# --------------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_USE_TLS=True
EMAIL_PORT=587
EMAIL_HOST_USER=user@user.com
EMAIL_HOST_PASSWORD=myverystrongpassword

# --------------------------------------------------------------------------------
# 🧠 Celery & Redis
# --------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6382/0
CELERY_BROKER_URL=redis://localhost:6379/0

# --------------------------------------------------------------------------------
# 🔐 Security Config: for production or testing the production settings locally.
# --------------------------------------------------------------------------------
ALLOWED_HOSTS=mysite.com,mysite2.com
CORS_ALLOWED_ORIGINS=mysite.com,mysite2.com
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --------------------------------------------------------------------------------
# 🔐 Clerk auth
# --------------------------------------------------------------------------------
# JWKS endpoint for verifying inbound session JWTs. Per-instance URL — find it
# under "API Keys → Show JWT public key" in the Clerk dashboard, or use:
#   https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
# Token issuer to check (same root as JWKS host, no trailing /).
CLERK_ISSUER=
# Expected `aud` claim. Leave blank to disable audience verification.
CLERK_AUDIENCE=
# Server-side secret (used by webhook svix verification + Clerk admin API).
CLERK_SECRET_KEY=
